# Django secret key (generate a new one!)
SECRET_KEY=django-insecure-change-me-in-production-use-python-secrets-module

# Database — PostgreSQL
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/instafood

# CORS: comma-separated list of allowed origins for production
CORS_ALLOWED_ORIGINS_PROD=https://yourdomain.com

# For SQLite (local dev fallback — comment out DATABASE_URL above and use this)
# SQLITE=true

DEBUG=True
